/* ===========================================================================
   arduino_secrets.h.example  —  template for BodyWifi's credentials

   COPY THIS FILE to `arduino_secrets.h` in this same folder and fill in your
   own values. BodyWifi.ino does #include "arduino_secrets.h" (quoted, so it
   resolves next to the sketch) and will not compile until that file exists.

       cp arduino_secrets.h.example arduino_secrets.h

   Every arduino_secrets.h under arduino/ is gitignored, so a real WiFi password
   never lands on GitHub. This .example template IS committed — so keep real
   values OUT of it.
   ---------------------------------------------------------------------------
   DASH_HOST is the DASH device's IP on the module network. Read it off DASH's
   Serial Monitor status line, which shows "Listening on <ip>:3274" once the
   WiFi transport is up.

   Both the DASH device and this module must be on the SAME network. A phone
   hotspot works; the tablet acting as the hotspot is the stable choice, since
   then its address does not move (module-sdk.md §12).
   ===========================================================================*/
#ifndef ARDUINO_SECRETS_H
#define ARDUINO_SECRETS_H

#define SECRET_SSID  "YOUR_WIFI_SSID"      // the network both DASH and this module join
#define SECRET_PASS  "YOUR_WIFI_PASSWORD"

#define DASH_HOST    "192.168.1.100"       // <-- the DASH device's IP (DHCP — recheck if it reconnects)
#define DASH_PORT    3274                  // the fixed DASH TCP port — leave as-is (transport.md)

#endif
