<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- WiFi TCP transport (1.4.11). INTERNET is a normal (auto-granted) permission; it lets DASH
         run its module TCP server. transport.md: the server is just an app on Android's network
         stack and does not affect concurrent internet use. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Weather-landing location, top of the cascade (1.5.4). COARSE is a runtime (dangerous)
         permission, but DASH never prompts for it — the no-nag rule. It is declared so that a user who
         grants it independently lights up the GPS tier transparently (capability detection); until
         then the scene falls through to keyless IP geolocation, which needs no permission. Either way
         weather only ever upgrades the offline clock-only floor. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Bluetooth Classic (SPP) transport (1.4.12). On API 31+ BLUETOOTH_CONNECT is a runtime
         (dangerous) permission — DASH requests it and degrades gracefully if denied (the transport
         reports unavailable and DASH carries on). We connect out to *already-bonded* devices only
         (pairing happens in Android's own Bluetooth settings, transport.md) and never scan for new
         ones, so BLUETOOTH_SCAN is not required. On API <=30 the legacy BLUETOOTH permission (normal,
         auto-granted) covers RFCOMM connect to a bonded device. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false" />

    <!-- USB serial transport (1.4.x). required=false keeps DASH installable on devices without
         USB host / OTG — the transport simply reports NO DEVICE and degrades gracefully. -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <application
        android:allowBackup="true"
        android:label="DASH"
        android:supportsRtl="true"
        android:theme="@style/Theme.Dash">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden">
            <!-- DASH manages its own responsive layout in Compose, so it handles rotation / resize
                 itself rather than being recreated. This keeps the open screen (settings, a monitor)
                 alive across a rotation — the UI reflows instead of restarting back to home. -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- USB one-time permission grant (roadmap 1.4.x). The device filter lets Android offer
                 "use by default" on first attach, so a serial device authorised once is not
                 re-prompted on every replug. device_filter.xml lists the standard serial VIDs. -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

        <receiver
            android:name=".launcher.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>